---
/**
 * analiticas.astro — Panel de Analíticas Antocarz
 *
 * Acceso: /analiticas?token=<ANALYTICS_TOKEN>
 * Env vars requeridas:
 *   ANALYTICS_TOKEN      → clave de acceso (ej. "antocarz2026")
 *   GA4_SERVICE_ACCOUNT  → JSON completo de la service account de Google
 *   GA4_PROPERTY_ID      → "530277574" (ya definida, se puede omitir)
 *
 * Setup service account:
 *   1. Google Cloud Console → IAM → Service Accounts → Crear
 *   2. Descargar JSON de credenciales
 *   3. En GA4 Admin → Administración de acceso → agregar el client_email como Viewer
 *   4. Pegar el JSON completo como valor de GA4_SERVICE_ACCOUNT en Vercel
 */

import { fetchAnalyticsSummary, type AnalyticsSummary } from '../lib/ga4';

const token      = Astro.url.searchParams.get('token');
const validToken = import.meta.env.ANALYTICS_TOKEN;

if (!validToken || token !== validToken) {
  return new Response('Acceso no autorizado', { status: 401 });
}

const propertyId = import.meta.env.GA4_PROPERTY_ID ?? '530277574';
const saJson     = import.meta.env.GA4_SERVICE_ACCOUNT ?? '';

let data: AnalyticsSummary | null = null;
let error: string | null = null;

if (!saJson) {
  error = 'Variable GA4_SERVICE_ACCOUNT no configurada. Agrégala en Vercel → Settings → Environment Variables.';
} else {
  try {
    data = await fetchAnalyticsSummary(propertyId, saJson);
  } catch (e) {
    error = e instanceof Error ? e.message : 'Error al obtener datos de GA4';
  }
}

const fmt = (n: number) => n.toLocaleString('es-CL');

const deviceTotal = data ? (data.mobile + data.desktop + data.tablet) || 1 : 1;
const mobilePct   = data ? Math.round((data.mobile  / deviceTotal) * 100) : 0;
const desktopPct  = data ? Math.round((data.desktop / deviceTotal) * 100) : 0;
const tabletPct   = 100 - mobilePct - desktopPct;

const userTotal = data ? (data.newUsers + data.returningUsers) || 1 : 1;
const newPct    = data ? Math.round((data.newUsers       / userTotal) * 100) : 0;
const returnPct = data ? Math.round((data.returningUsers / userTotal) * 100) : 0;

const rateColor = !data ? '#666'
  : data.conversionRate >= 3 ? '#2ECC71'
  : data.conversionRate >= 1 ? '#F39C12'
  : '#E30613';

const rateLabel = !data ? ''
  : data.conversionRate >= 3 ? 'Excelente'
  : data.conversionRate >= 1 ? 'Normal'
  : 'Bajo';

const updatedAt = new Date().toLocaleDateString('es-CL', {
  day: 'numeric', month: 'long', year: 'numeric',
  hour: '2-digit', minute: '2-digit',
});
---

<!doctype html>
<html lang="es-CL">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Analíticas — Antocarz</title>
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        background: #0D0D0D;
        color: #fff;
        min-height: 100vh;
        line-height: 1.5;
      }

      /* ── Header ── */
      .panel-header {
        border-bottom: 1px solid rgba(227, 6, 19, 0.2);
        padding: 1.25rem 2rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 0.75rem;
        background: #111;
        position: sticky;
        top: 0;
        z-index: 10;
      }
      .panel-brand {
        display: flex;
        align-items: center;
        gap: 0.875rem;
      }
      .panel-brand__logo {
        width: 36px;
        height: 36px;
        background: #E30613;
        border-radius: 9px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
        font-weight: 900;
        flex-shrink: 0;
        letter-spacing: -0.02em;
      }
      .panel-brand__name {
        font-size: 1.125rem;
        font-weight: 700;
        color: #fff;
      }
      .panel-brand__badge {
        font-size: 0.75rem;
        color: #555;
        margin-top: 1px;
      }
      .panel-meta {
        text-align: right;
        font-size: 0.8rem;
        color: #555;
        line-height: 1.6;
      }
      .panel-meta strong { color: #888; font-weight: 500; }

      /* ── Main ── */
      .panel-main {
        padding: 2rem 1.5rem 3rem;
        max-width: 1240px;
        margin: 0 auto;
      }

      /* ── Error ── */
      .panel-error {
        background: rgba(227, 6, 19, 0.06);
        border: 1px solid rgba(227, 6, 19, 0.25);
        border-radius: 12px;
        padding: 2.5rem 2rem;
        text-align: center;
        max-width: 560px;
        margin: 4rem auto;
      }
      .panel-error__icon { font-size: 2.5rem; margin-bottom: 1rem; display: block; }
      .panel-error__title { font-size: 1.25rem; font-weight: 700; margin-bottom: 0.625rem; }
      .panel-error__msg { font-size: 0.875rem; color: #666; line-height: 1.7; }

      /* ── Grid ── */
      .panel-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 1.5rem;
      }

      /* ── Card base ── */
      .card {
        background: #181818;
        border: 1px solid rgba(227, 6, 19, 0.15);
        border-radius: 16px;
        padding: 1.75rem;
        transition: border-color 200ms ease, box-shadow 200ms ease;
      }
      .card:hover {
        border-color: rgba(227, 6, 19, 0.32);
        box-shadow: 0 4px 24px rgba(227, 6, 19, 0.07);
      }
      .card__header {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 1.375rem;
      }
      .card__icon {
        width: 40px;
        height: 40px;
        background: rgba(227, 6, 19, 0.1);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.125rem;
        flex-shrink: 0;
      }
      .card__title {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.09em;
        color: #555;
        font-weight: 700;
      }
      .card__subtitle {
        font-size: 0.75rem;
        color: #444;
        margin-top: 2px;
      }

      /* ── KPI ── */
      .kpi__value {
        font-size: 3.25rem;
        font-weight: 800;
        color: #fff;
        letter-spacing: -0.04em;
        line-height: 1;
        margin-bottom: 0.5rem;
      }
      .kpi__context { font-size: 0.875rem; color: #666; }
      .kpi__context strong { color: #aaa; font-weight: 600; }

      /* ── Rate badge ── */
      .rate-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.375rem;
        font-size: 0.7rem;
        font-weight: 700;
        padding: 0.2rem 0.6rem;
        border-radius: 999px;
        margin-bottom: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.06em;
      }
      .rate-badge__dot {
        width: 6px; height: 6px;
        border-radius: 50%;
        flex-shrink: 0;
      }

      /* ── Bar list ── */
      .bar-list { display: flex; flex-direction: column; gap: 1rem; }
      .bar-label {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        margin-bottom: 0.375rem;
      }
      .bar-name { font-size: 0.875rem; color: #bbb; }
      .bar-value { font-size: 0.8rem; color: #555; font-variant-numeric: tabular-nums; }
      .bar-track {
        height: 6px;
        background: rgba(255,255,255,0.05);
        border-radius: 999px;
        overflow: hidden;
      }
      .bar-fill {
        height: 100%;
        border-radius: 999px;
        background: #E30613;
      }
      .bar-fill--2 { background: rgba(227, 6, 19, 0.5); }
      .bar-fill--3 { background: rgba(227, 6, 19, 0.3); }
      .bar-fill--4 { background: rgba(227, 6, 19, 0.15); }

      /* ── Page list ── */
      .page-list { display: flex; flex-direction: column; gap: 0.75rem; }
      .page-item {
        display: flex;
        align-items: center;
        gap: 0.875rem;
      }
      .page-rank {
        font-size: 0.7rem;
        font-weight: 700;
        color: #333;
        width: 1.25rem;
        text-align: center;
        flex-shrink: 0;
      }
      .page-path {
        font-size: 0.8rem;
        color: #999;
        font-family: 'SF Mono', 'Fira Code', 'Consolas', monospace;
        flex: 1;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }
      .page-views {
        font-size: 0.8rem;
        font-weight: 600;
        color: #555;
        flex-shrink: 0;
        font-variant-numeric: tabular-nums;
      }

      /* ── Split ── */
      .split-track {
        height: 8px;
        border-radius: 999px;
        overflow: hidden;
        display: flex;
        margin-bottom: 1.25rem;
        background: rgba(255,255,255,0.04);
      }
      .split-a {
        background: #E30613;
        border-radius: 999px 0 0 999px;
      }
      .split-b { background: rgba(227, 6, 19, 0.25); flex: 1; }
      .split-legend { display: flex; gap: 2rem; }
      .split-item { display: flex; flex-direction: column; gap: 0.15rem; }
      .split-label { font-size: 0.75rem; color: #555; }
      .split-label span {
        display: inline-block;
        width: 8px; height: 8px;
        border-radius: 50%;
        margin-right: 0.35rem;
        vertical-align: middle;
      }
      .split-val { font-size: 1.5rem; font-weight: 700; color: #fff; letter-spacing: -0.02em; }
      .split-pct { font-size: 0.75rem; color: #444; }

      /* ── Footer ── */
      .panel-footer {
        text-align: center;
        padding: 1.5rem 2rem 2.5rem;
        font-size: 0.75rem;
        color: #2a2a2a;
      }
      .panel-footer a { color: #3a3a3a; text-decoration: none; }
      .panel-footer a:hover { color: #666; }

      /* ── Responsive ── */
      @media (max-width: 640px) {
        .panel-header { padding: 1rem 1.25rem; }
        .panel-main { padding: 1.25rem 1rem 2rem; }
        .panel-grid { grid-template-columns: 1fr; }
        .kpi__value { font-size: 2.75rem; }
      }
    </style>
  </head>
  <body>

    <header class="panel-header">
      <div class="panel-brand">
        <div class="panel-brand__logo">A</div>
        <div>
          <div class="panel-brand__name">Antocarz</div>
          <div class="panel-brand__badge">Panel de Analíticas · Últimos 30 días</div>
        </div>
      </div>
      <div class="panel-meta">
        <strong>Actualizado</strong><br />{updatedAt}
      </div>
    </header>

    <main class="panel-main">

      {error && (
        <div class="panel-error">
          <span class="panel-error__icon">⚠️</span>
          <div class="panel-error__title">No se pudieron cargar los datos</div>
          <p class="panel-error__msg">{error}</p>
        </div>
      )}

      {data && (
        <div class="panel-grid">

          {/* ── 1. Visitas al sitio ── */}
          <div class="card">
            <div class="card__header">
              <div class="card__icon">📊</div>
              <div>
                <div class="card__title">Visitas al sitio</div>
                <div class="card__subtitle">Sesiones · últimos 30 días</div>
              </div>
            </div>
            <div class="kpi__value">{fmt(data.sessions)}</div>
            <p class="kpi__context">
              <strong>{fmt(data.users)}</strong> usuarios únicos en el período
            </p>
          </div>

          {/* ── 2. Tasa de contacto WhatsApp ── */}
          <div class="card">
            <div class="card__header">
              <div class="card__icon">💬</div>
              <div>
                <div class="card__title">Contacto por WhatsApp</div>
                <div class="card__subtitle">Visitas que hacen clic en WA</div>
              </div>
            </div>
            <div
              class="rate-badge"
              style={`color: ${rateColor}; background: ${rateColor}18;`}
            >
              <span class="rate-badge__dot" style={`background: ${rateColor};`}></span>
              {rateLabel}
            </div>
            <div class="kpi__value" style={`color: ${rateColor};`}>
              {data.conversionRate.toFixed(1)}%
            </div>
            <p class="kpi__context">
              <strong>{fmt(data.waClicks)}</strong> consultas de {fmt(data.sessions)} visitas totales
            </p>
          </div>

          {/* ── 3. Origen del tráfico ── */}
          <div class="card">
            <div class="card__header">
              <div class="card__icon">🌐</div>
              <div>
                <div class="card__title">Origen del tráfico</div>
                <div class="card__subtitle">¿Cómo te encuentran?</div>
              </div>
            </div>
            <div class="bar-list">
              {data.channels.map((ch, i) => (
                <div>
                  <div class="bar-label">
                    <span class="bar-name">{ch.name}</span>
                    <span class="bar-value">{ch.pct}% · {fmt(ch.sessions)}</span>
                  </div>
                  <div class="bar-track">
                    <div
                      class={`bar-fill${i === 1 ? ' bar-fill--2' : i === 2 ? ' bar-fill--3' : i >= 3 ? ' bar-fill--4' : ''}`}
                      style={`width: ${ch.pct}%;`}
                    ></div>
                  </div>
                </div>
              ))}
            </div>
          </div>

          {/* ── 4. Páginas más vistas ── */}
          <div class="card">
            <div class="card__header">
              <div class="card__icon">📄</div>
              <div>
                <div class="card__title">Páginas más vistas</div>
                <div class="card__subtitle">¿Qué servicio genera más interés?</div>
              </div>
            </div>
            <div class="page-list">
              {data.topPages.map((pg, i) => (
                <div class="page-item">
                  <span class="page-rank">#{i + 1}</span>
                  <span class="page-path">{pg.path}</span>
                  <span class="page-views">{fmt(pg.views)}</span>
                </div>
              ))}
            </div>
          </div>

          {/* ── 5. Nuevos vs Recurrentes ── */}
          <div class="card">
            <div class="card__header">
              <div class="card__icon">👥</div>
              <div>
                <div class="card__title">Audiencia</div>
                <div class="card__subtitle">Visitantes nuevos vs. recurrentes</div>
              </div>
            </div>
            <div class="split-track">
              <div class="split-a" style={`width: ${newPct}%;`}></div>
              <div class="split-b"></div>
            </div>
            <div class="split-legend">
              <div class="split-item">
                <span class="split-label">
                  <span style="background:#E30613;"></span>Nuevos
                </span>
                <span class="split-val">{fmt(data.newUsers)}</span>
                <span class="split-pct">{newPct}% del total</span>
              </div>
              <div class="split-item">
                <span class="split-label">
                  <span style="background:rgba(227,6,19,0.3);"></span>Recurrentes
                </span>
                <span class="split-val">{fmt(data.returningUsers)}</span>
                <span class="split-pct">{returnPct}% del total</span>
              </div>
            </div>
          </div>

          {/* ── 6. Dispositivos ── */}
          <div class="card">
            <div class="card__header">
              <div class="card__icon">📱</div>
              <div>
                <div class="card__title">Dispositivos</div>
                <div class="card__subtitle">¿Cómo acceden tus clientes?</div>
              </div>
            </div>
            <div class="bar-list">
              <div>
                <div class="bar-label">
                  <span class="bar-name">📱 Móvil</span>
                  <span class="bar-value">{mobilePct}% · {fmt(data.mobile)}</span>
                </div>
                <div class="bar-track">
                  <div class="bar-fill" style={`width: ${mobilePct}%;`}></div>
                </div>
              </div>
              <div>
                <div class="bar-label">
                  <span class="bar-name">🖥️ Escritorio</span>
                  <span class="bar-value">{desktopPct}% · {fmt(data.desktop)}</span>
                </div>
                <div class="bar-track">
                  <div class="bar-fill bar-fill--2" style={`width: ${desktopPct}%;`}></div>
                </div>
              </div>
              {data.tablet > 0 && (
                <div>
                  <div class="bar-label">
                    <span class="bar-name">💻 Tablet</span>
                    <span class="bar-value">{tabletPct}% · {fmt(data.tablet)}</span>
                  </div>
                  <div class="bar-track">
                    <div class="bar-fill bar-fill--3" style={`width: ${tabletPct}%;`}></div>
                  </div>
                </div>
              )}
            </div>
          </div>

        </div>
      )}
    </main>

    <footer class="panel-footer">
      Generado por <a href="https://gautamadigital.cl" target="_blank" rel="noopener">Gautama Digital</a>
      &nbsp;·&nbsp; Solo para uso interno &nbsp;·&nbsp; Datos de Google Analytics 4
    </footer>

  </body>
</html>
