---
/**
 * BaseLayout.astro — Antocarz
 * Layout base con SEO completo, Schema JSON-LD y OG tags.
 */

import { SITE } from '../content/site';
import { FAQ_ITEMS } from '../content/faq';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import '../styles/global.css';
import '../styles/animations.css';

export interface BaseLayoutProps {
  title?: string;
  description?: string;
  canonicalUrl?: string;
  noIndex?: boolean;
}

const {
  title = `${SITE.name} — ${SITE.tagline}`,
  description = SITE.description,
  canonicalUrl = SITE.url,
  noIndex = false,
} = Astro.props as BaseLayoutProps;

const schemaLocalBusiness = {
  '@context': 'https://schema.org',
  '@type': 'AutoPartsStore',
  '@id': `${SITE.url}/#business`,
  name: SITE.name,
  description: SITE.description,
  url: SITE.url,
  telephone: SITE.phone,
  email: SITE.email,
  address: {
    '@type': 'PostalAddress',
    streetAddress: SITE.location.address,
    addressLocality: SITE.location.city,
    addressRegion: SITE.location.region,
    addressCountry: SITE.location.country,
  },
  openingHoursSpecification: [
    { '@type': 'OpeningHoursSpecification', dayOfWeek: ['Monday','Tuesday','Wednesday','Thursday','Friday'], opens: '09:30', closes: '18:00' },
    { '@type': 'OpeningHoursSpecification', dayOfWeek: ['Saturday'], opens: '09:30', closes: '14:00' },
  ],
  areaServed: [
    { '@type': 'City', name: 'La Serena' },
    { '@type': 'City', name: 'Coquimbo' },
    { '@type': 'City', name: 'Ovalle' },
  ],
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.7',
    bestRating: '5',
    worstRating: '1',
    ratingCount: '223',
  },
  sameAs: [
    SITE.social.instagram,
    SITE.social.facebook,
  ],
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Servicios de Equipamiento Automotriz',
    itemListElement: [
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Instalación de Radio Android con CarPlay y GPS' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Instalación de Alarmas Homologadas' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Polarizado Legal Certificado' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Instalación de Cámaras de Retroceso' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Iluminación LED Automotriz' } },
    ],
  },
  priceRange: '$$',
  inLanguage: 'es-CL',
};

const schemaFAQPage = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: FAQ_ITEMS.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: { '@type': 'Answer', text: item.answer },
  })),
};

const gaId = import.meta.env.PUBLIC_GA_ID;
---

<!doctype html>
<html lang="es-CL" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="google-site-verification" content="gwuXaEyJImHdmJjQPsKvbeXsrXmJjXwylFPVS59Q7hw" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Google Analytics -->
    {gaId && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
        <script define:vars={{ gaId }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', gaId);
        </script>
      </>
    )}
    {noIndex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${SITE.url}/og-image.jpg`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:locale" content="es_CL" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${SITE.url}/og-image.jpg`} />

    <!-- Local SEO -->
    <meta name="geo.region" content="CL-CO" />
    <meta name="geo.placename" content="La Serena, Chile" />
    <meta name="geo.position" content="-29.9027;-71.2519" />
    <meta name="ICBM" content="-29.9027, -71.2519" />

    <!-- Keywords SEO -->
    <meta name="keywords" content="car audio La Serena, radio android CarPlay La Serena, Android Auto La Serena, GPS auto La Serena, alarmas homologadas La Serena, polarizado legal La Serena, cámara retroceso La Serena, ZTAudio, rastreadores.cl, inmovilizador RFID, antocarz" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Preload primera imagen hero (LCP) -->
    <link rel="preload" as="image" href="/slides hero/BANNER POLARIZADOS.webp" />

    <!-- Preconnect al servidor de imágenes de productos -->
    <link rel="preconnect" href="https://antocarz.cl" />
    <link rel="dns-prefetch" href="https://antocarz.cl" />

    <!-- Google Fonts: Lato — carga no bloqueante -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Lato:wght@300;400;700;900&display=swap" />
    <link href="https://fonts.googleapis.com/css2?family=Lato:wght@300;400;700;900&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />
    <noscript><link href="https://fonts.googleapis.com/css2?family=Lato:wght@300;400;700;900&display=swap" rel="stylesheet" /></noscript>

    <!-- Schema JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(schemaLocalBusiness)} />
    <script type="application/ld+json" set:html={JSON.stringify(schemaFAQPage)} />

    <meta name="theme-color" content="#0D0D0D" />

    <!-- Prevenir flash de tema incorrecto (inline, no module) -->
    <script is:inline>
      (function() {
        const saved = localStorage.getItem('antocarz-theme');
        if (saved === 'light') {
          document.documentElement.setAttribute('data-theme', 'light');
        }
      })();
    </script>
  </head>

  <body>
    <!-- Efecto Difuminado Global de Rejilla -->
    <div class="bg-hazard-glow"></div>
    
    <!-- Marca de agua gigante y sutil del logo (el perro) -->
    <div class="bg-dog-watermark"></div>
    <Header />
    <main id="main-content" tabindex="-1">
      <slot />
    </main>
    <Footer />

    <!-- Branch Selection Modal -->
    <div class="branch-modal-overlay" id="branchModal" aria-hidden="true">
      <div class="branch-modal">
        <button class="branch-modal__close" id="closeBranchModal" aria-label="Cerrar">&times;</button>
        <span class="branch-modal__icon">📍</span>
        <h3 class="branch-modal__title">¿En qué sucursal deseas cotizar?</h3>
        <p class="branch-modal__desc">Elige el local que más te acomoda para enviarnos tu solicitud vía WhatsApp de forma directa y agilizar tu atención.</p>
        
        <div class="branch-modal__actions">
          <button class="branch-btn" data-branch="Lautaro" data-wa="56997371969">
            <span class="branch-btn__title">Sucursal Lautaro</span>
            <span class="branch-btn__address">Lautaro 812, La Serena</span>
          </button>
          <button class="branch-btn" data-branch="Balmaceda" data-wa="56931258163">
            <span class="branch-btn__title">Sucursal Balmaceda</span>
            <span class="branch-btn__address">Balmaceda 2033, La Serena</span>
          </button>
        </div>
      </div>
    </div>

    <style is:global>
      /* --- Modal de Sucursales --- */
      .branch-modal-overlay {
        position: fixed;
        inset: 0;
        z-index: var(--z-modal);
        background: rgba(0, 0, 0, 0.85);
        backdrop-filter: blur(8px);
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        visibility: hidden;
        transition: opacity var(--transition-base), visibility var(--transition-base);
        padding: var(--space-4);
      }
      .branch-modal-overlay--active {
        opacity: 1;
        visibility: visible;
      }

      .branch-modal {
        background: var(--color-bg-surface);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-2xl);
        padding: var(--space-8);
        width: 100%;
        max-width: 500px;
        position: relative;
        text-align: center;
        transform: translateY(20px) scale(0.95);
        transition: transform var(--transition-spring);
        box-shadow: 0 25px 50px rgba(0, 0, 0, 0.5), 0 0 40px rgba(227, 6, 19, 0.1);
      }
      .branch-modal-overlay--active .branch-modal {
        transform: translateY(0) scale(1);
      }

      .branch-modal__close {
        position: absolute;
        top: 20px;
        right: 20px;
        background: rgba(255,255,255,0.05);
        border: none;
        color: var(--color-text-muted);
        width: 36px;
        height: 36px;
        border-radius: 50%;
        font-size: 1.5rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background var(--transition-fast), color var(--transition-fast);
      }
      .branch-modal__close:hover {
        background: rgba(255,255,255,0.1);
        color: #fff;
      }

      .branch-modal__icon {
        font-size: 3rem;
        display: block;
        margin-bottom: var(--space-4);
      }

      .branch-modal__title {
        font-size: var(--text-2xl);
        margin-bottom: var(--space-2);
        color: #fff;
      }

      .branch-modal__desc {
        font-size: var(--text-sm);
        color: var(--color-text-secondary);
        margin-bottom: var(--space-8);
        line-height: var(--leading-relaxed);
      }

      .branch-modal__actions {
        display: flex;
        flex-direction: column;
        gap: var(--space-4);
      }

      .branch-btn {
        width: 100%;
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.1);
        padding: var(--space-5);
        border-radius: var(--radius-xl);
        cursor: pointer;
        transition: all var(--transition-base);
        text-align: left;
        display: flex;
        flex-direction: column;
        gap: 4px;
        position: relative;
        overflow: hidden;
      }
      
      .branch-btn::before {
        content: '';
        position: absolute;
        top: 0; left: 0; width: 4px; height: 100%;
        background: var(--color-gold);
        opacity: 0;
        transition: opacity var(--transition-fast);
      }

      .branch-btn:hover {
        background: rgba(255,255,255,0.06);
        border-color: rgba(227, 6, 19, 0.4);
        transform: translateY(-2px);
      }
      
      .branch-btn:hover::before {
        opacity: 1;
      }

      .branch-btn__title {
        font-size: var(--text-lg);
        font-weight: var(--weight-bold);
        color: #fff;
        font-family: var(--font-headline);
      }

      .branch-btn__address {
        font-size: var(--text-sm);
        color: var(--color-text-muted);
      }
    </style>

    <script>
      import { initScrollReveal } from '../utils/animations';
      setTimeout(() => initScrollReveal(), 300);

      // --- Lógica del Modal de Sucursales ---
      const branchModal = document.getElementById('branchModal');
      const closeObj = document.getElementById('closeBranchModal');
      const branchBtns = document.querySelectorAll('.branch-btn');
      let pendingWaUrl = '';

      document.querySelectorAll('a[href*="wa.me"]').forEach(link => {
        link.addEventListener('click', (e) => {
          const href = (link as HTMLAnchorElement).href;
          // Si el botón ya tiene texto específico de sucursal (ej. el de LocalMap), no mostramos el popup
          if (href.toLowerCase().includes('sucursal%20lautaro') || href.toLowerCase().includes('sucursal%20balmaceda')) {
            return;
          }
          e.preventDefault();
          pendingWaUrl = href;
          branchModal?.classList.add('branch-modal-overlay--active');
          branchModal?.setAttribute('aria-hidden', 'false');
        });
      });

      closeObj?.addEventListener('click', () => {
        branchModal?.classList.remove('branch-modal-overlay--active');
        branchModal?.setAttribute('aria-hidden', 'true');
      });

      // Cerrar al clickear afuera
      branchModal?.addEventListener('click', (e) => {
        if (e.target === branchModal) {
          branchModal.classList.remove('branch-modal-overlay--active');
          branchModal.setAttribute('aria-hidden', 'true');
        }
      });

      branchBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          const branchName = btn.getAttribute('data-branch');
          const branchWa = btn.getAttribute('data-wa');
          try {
            const url = new URL(pendingWaUrl);
            let text = url.searchParams.get('text') || 'Hola, quiero una cotización.';
            text = text.replace('Hola Antocarz', `Hola Antocarz sucursal ${branchName}`);
            url.searchParams.set('text', text);
            
            let finalUrl = url.toString();
            // Reemplazamos el número global de la URL por el número específico de la sucursal seleccionada
            finalUrl = finalUrl.replace(/569\d{8}/, branchWa);
            
            window.open(finalUrl, '_blank');
          } catch (error) {
            window.open(pendingWaUrl, '_blank');
          }
          branchModal?.classList.remove('branch-modal-overlay--active');
        });
      });
    </script>
  </body>
</html>
