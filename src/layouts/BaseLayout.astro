---
/**
 * BaseLayout.astro — Antocarz
 * Layout base con SEO completo, Schema JSON-LD y OG tags.
 */

import { SITE } from '../content/site';
import { FAQ_ITEMS } from '../content/faq';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import '../styles/global.css';
import '../styles/animations.css';

export interface BaseLayoutProps {
  title?: string;
  description?: string;
  canonicalUrl?: string;
  noIndex?: boolean;
}

const {
  title = `${SITE.name} — ${SITE.tagline}`,
  description = SITE.description,
  canonicalUrl = SITE.url,
  noIndex = false,
} = Astro.props as BaseLayoutProps;

const schemaLocalBusiness = {
  '@context': 'https://schema.org',
  '@type': 'AutoPartsStore',
  '@id': `${SITE.url}/#business`,
  name: SITE.name,
  description: SITE.description,
  url: SITE.url,
  telephone: SITE.phone,
  email: SITE.email,
  address: {
    '@type': 'PostalAddress',
    streetAddress: SITE.location.address,
    addressLocality: SITE.location.city,
    addressRegion: SITE.location.region,
    addressCountry: SITE.location.country,
  },
  openingHoursSpecification: [
    { '@type': 'OpeningHoursSpecification', dayOfWeek: ['Monday','Tuesday','Wednesday','Thursday','Friday'], opens: '09:30', closes: '18:00' },
    { '@type': 'OpeningHoursSpecification', dayOfWeek: ['Saturday'], opens: '09:30', closes: '14:00' },
  ],
  areaServed: [
    { '@type': 'City', name: 'La Serena' },
    { '@type': 'City', name: 'Coquimbo' },
  ],
  priceRange: '$$',
  inLanguage: 'es-CL',
};

const schemaFAQPage = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: FAQ_ITEMS.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: { '@type': 'Answer', text: item.answer },
  })),
};
---

<!doctype html>
<html lang="es-CL" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {noIndex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${SITE.url}/og-image.jpg`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:locale" content="es_CL" />

    <!-- Local SEO -->
    <meta name="geo.region" content="CL-CO" />
    <meta name="geo.placename" content="La Serena, Chile" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Google Fonts: Lato -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Lato:wght@300;400;700;900&display=swap" rel="stylesheet" />

    <!-- Schema JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(schemaLocalBusiness)} />
    <script type="application/ld+json" set:html={JSON.stringify(schemaFAQPage)} />

    <meta name="theme-color" content="#0D0D0D" />

    <!-- Prevenir flash de tema incorrecto (inline, no module) -->
    <script is:inline>
      (function() {
        const saved = localStorage.getItem('antocarz-theme');
        if (saved === 'light') {
          document.documentElement.setAttribute('data-theme', 'light');
        }
      })();
    </script>
  </head>

  <body>
    <Header />
    <main id="main-content" tabindex="-1">
      <slot />
    </main>
    <Footer />

    <script>
      import { initScrollReveal } from '../utils/animations';
      setTimeout(() => initScrollReveal(), 300);
    </script>
  </body>
</html>
