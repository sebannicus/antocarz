---
/**
 * ServiceCard.astro — Antocarz
 * Tarjeta de servicio con imagen o carrusel táctil invisible (scroll-snap).
 */

import type { Service } from '../../content/services';

export interface ServiceCardProps {
  service: Service;
}

const { service } = Astro.props as ServiceCardProps;
const hasCarousel = service.images && service.images.length > 1;
const cardId = `sc-${Math.random().toString(36).slice(2, 8)}`;
---

<article class:list={['service-card', 'hover-lift', 'gs-fade-up']}>
  {service.badge && (
    <span class="service-card__badge">{service.badge}</span>
  )}

  <div class="service-card__img-wrap">
    {hasCarousel ? (
      <div class="sc-carousel" id={cardId} aria-label={`Imágenes de ${service.title}`}>
        {service.images!.map((src, i) => (
          <div class="sc-carousel__slide">
            <img
              src={src}
              alt={i === 0 ? service.title : `${service.title} ${i + 1}`}
              class="service-card__img"
              width="480"
              height="260"
              loading={i === 0 ? 'eager' : 'lazy'}
            />
          </div>
        ))}
      </div>
    ) : (
      <img
        src={service.image}
        alt={service.title}
        class="service-card__img"
        width="480"
        height="260"
        loading="lazy"
      />
    )}
    <div class="service-card__img-overlay" aria-hidden="true"></div>
  </div>

  <div class="service-card__body">
    <h3 class="service-card__title">{service.title}</h3>
    <p class="service-card__desc">{service.description}</p>
    <ul class="service-card__features">
      {service.features.map((f) => (
        <li class="service-card__feature">
          <span class="service-card__check" aria-hidden="true">✓</span>
          {f}
        </li>
      ))}
    </ul>
  </div>
</article>

<style>
  .service-card {
    position: relative;
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: border-color var(--transition-base), box-shadow var(--transition-slow);
  }

  .service-card:hover {
    border-color: var(--color-border-hover);
    box-shadow: var(--shadow-gold);
  }

  .service-card__badge {
    position: absolute;
    top: var(--space-4);
    right: var(--space-4);
    z-index: 2;
    background: var(--color-gold);
    color: #FFFFFF;
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
    text-transform: uppercase;
  }

  /* Imagen / Carrusel */
  .service-card__img-wrap {
    position: relative;
    aspect-ratio: 16 / 8;
    overflow: hidden;
    flex-shrink: 0;
  }

  /* Carrusel scroll-snap */
  .sc-carousel {
    display: flex;
    width: 100%;
    height: 100%;
    overflow-x: scroll;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .sc-carousel::-webkit-scrollbar { display: none; }

  .sc-carousel__slide {
    flex: 0 0 100%;
    width: 100%;
    height: 100%;
    scroll-snap-align: start;
    overflow: hidden;
  }

  .service-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform var(--transition-slow);
  }

  /* El scale en hover solo aplica a imagen única */
  .service-card:hover > .service-card__img-wrap > .service-card__img {
    transform: scale(1.05);
  }

  /* Overlay con icono grande centrado */
  .service-card__img-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.72) 0%, rgba(0,0,0,0.10) 60%, transparent 100%);
    display: flex;
    align-items: flex-end;
    justify-content: flex-start;
    padding: var(--space-4);
    transition: background var(--transition-base);
    pointer-events: none;
    z-index: 1;
  }

  .service-card:hover .service-card__img-overlay {
    background: linear-gradient(to top, rgba(227,6,19,0.75) 0%, rgba(0,0,0,0.15) 60%, transparent 100%);
  }

  .service-card__icon {
    font-size: 2.2rem;
    line-height: 1;
    filter: drop-shadow(0 2px 8px rgba(0,0,0,0.5));
  }

  /* Body */
  .service-card__body {
    padding: var(--space-6) var(--space-6) var(--space-7);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    flex: 1;
  }

  .service-card__title {
    font-size: var(--text-xl);
    font-weight: var(--weight-bold);
    color: var(--color-text-primary);
  }

  .service-card__desc {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
  }

  .service-card__features {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-top: auto;
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border);
  }

  .service-card__feature {
    display: flex;
    align-items: flex-start;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
  }

  .service-card__check {
    color: var(--color-gold);
    font-weight: var(--weight-bold);
    flex-shrink: 0;
    margin-top: 1px;
  }
</style>
