---
/**
 * Footer.astro — Antocarz
 */

import { SITE } from '../../content/site';

const year = new Date().getFullYear();
const whatsappMsg = encodeURIComponent('Hola, quiero cotizar un servicio para mi vehículo.');
const whatsappUrl = `https://wa.me/${SITE.whatsapp}?text=${whatsappMsg}`;
---

<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__brand">
      <a href="/" class="footer__logo" aria-label="Antocarz — Inicio">
        <img src="/logos/PNG PEQUE LOGO.webp" alt="Antocarz" class="footer__logo-img" />
      </a>
      <p class="footer__tagline">{SITE.tagline}</p>
    </div>

    <div class="footer__contact">
      <a href={`tel:${SITE.phone}`} class="footer__link">📞 {SITE.phone}</a>
      <a href={`mailto:${SITE.email}`} class="footer__link">✉️ {SITE.email}</a>
      <a href={SITE.location.mapsUrl} target="_blank" rel="noopener noreferrer" class="footer__link">
        📍 {SITE.location.address}, {SITE.location.city}
      </a>
    </div>

    <div class="footer__hours">
      <p class="footer__hours-title">Horario</p>
      <p>{SITE.hours.weekdays}</p>
      <p>{SITE.hours.saturday}</p>
      <p>{SITE.hours.sunday}</p>
    </div>
  </div>

  <div class="footer__bottom">
    <p>© {year} {SITE.name}. Todos los derechos reservados.</p>
    <p>Sitio desarrollado por <a href="https://gautamadigital.cl" target="_blank" rel="noopener noreferrer" class="footer__dev-link">Gautama Digital</a></p>
  </div>

  <!-- WhatsApp flotante con badge de texto -->
  <a
    href={whatsappUrl}
    class="footer__whatsapp"
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Cotizar por WhatsApp"
  >
    <svg class="footer__whatsapp-icon" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
    </svg>
    <span class="footer__whatsapp-label">Cotizar</span>
  </a>
</footer>

<style>
  .footer {
    background: var(--color-bg-surface);
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-16);
  }

  .footer__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-10);
    padding-bottom: var(--space-12);
  }

  @media (min-width: 768px) {
    .footer__inner {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .footer__logo {
    display: inline-block;
    margin-bottom: var(--space-3);
  }
  .footer__logo-img {
    height: 90px;
    width: auto;
    display: block;
    object-fit: contain;
  }

  .footer__tagline {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
  }

  .footer__contact {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .footer__link {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    transition: color var(--transition-fast);
  }
  .footer__link:hover { color: var(--color-gold); }

  .footer__hours { display: flex; flex-direction: column; gap: var(--space-2); }

  .footer__hours-title {
    font-weight: var(--weight-semibold);
    color: var(--color-text-primary);
    font-size: var(--text-sm);
    margin-bottom: var(--space-1);
  }

  .footer__hours p {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
  }

  .footer__bottom {
    border-top: 1px solid var(--color-border);
    padding-block: var(--space-6);
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: var(--space-3);
  }

  .footer__bottom p {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .footer__dev-link {
    color: var(--color-gold);
    transition: opacity var(--transition-fast);
  }
  .footer__dev-link:hover { opacity: 0.8; }


  /* WhatsApp flotante */
  .footer__whatsapp {
    position: fixed;
    bottom: var(--space-6);
    right: var(--space-6);
    z-index: var(--z-top);
    height: 52px;
    padding: 0 var(--space-5) 0 var(--space-4);
    background: #25D366;
    color: #FFFFFF;
    border-radius: var(--radius-full);
    display: flex;
    align-items: center;
    gap: var(--space-2);
    box-shadow: 0 4px 20px rgba(37, 211, 102, 0.40);
    transition: transform var(--transition-spring), box-shadow var(--transition-base), padding var(--transition-base);
  }
  .footer__whatsapp:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 28px rgba(37, 211, 102, 0.55);
  }
  .footer__whatsapp-icon { flex-shrink: 0; }
  .footer__whatsapp-label {
    font-family: var(--font-subhead);
    font-size: var(--text-sm);
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-wide);
    white-space: nowrap;
  }
</style>
