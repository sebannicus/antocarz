---
/**
 * CtaFinal.astro — Antocarz
 * Cierre de página: CTA de conversión a WhatsApp con selector de sucursal.
 */

import Button from '../ui/Button.astro';
import { SITE } from '../../content/site';

const branches = SITE.branches;
---

<section class="cta-final section" id="contacto" aria-label="Llamada a la acción final">
  <!-- Glows -->
  <div class="bg-glow bg-glow--gold cta-final__glow cta-final__glow--1" aria-hidden="true"></div>
  <div class="bg-glow bg-glow--violet cta-final__glow cta-final__glow--2" aria-hidden="true"></div>

  <div class="container container--sm">
    <div class="cta-final__inner" data-scroll-children>

      <!-- Logo prominente antes del CTA -->
      <img
        src="/logos/PNG PEQUE LOGO.webp"
        alt="Antocarz"
        class="cta-final__logo"
        width="180"
        height="80"
        loading="lazy"
      />

      <span class="cta-final__label" aria-hidden="true">
        <span class="cta-final__dot"></span>
        Respuesta en menos de 1 hora
      </span>

      <h2 class="cta-final__title">
        ¿Listo para equipar<br />
        <span class="text-gradient-gold">tu auto?</span>
      </h2>

      <p class="cta-final__sub">
        Cuéntanos qué necesitas y te cotizamos al instante por WhatsApp.
        Sin compromisos, sin esperas.
      </p>

      <!-- Branch selector -->
      <div class="cta-final__branches">
        <p class="cta-final__branches-label">¿En qué sucursal nos visitas?</p>
        <div class="cta-final__cta-branch-btns">
          {branches.map((branch) => {
            const url = `https://wa.me/${branch.whatsappNumber}?text=${encodeURIComponent(branch.whatsappMsg)}`;
            return (
              <a
                href={url}
                class="cta-cta-branch-btn"
                target="_blank"
                rel="noopener noreferrer"
                data-wa-source="contacto"
                data-wa-branch={branch.name.replace('Sucursal ', '')}
                aria-label={`Cotizar por WhatsApp — ${branch.name}`}
              >
                <span class="cta-cta-branch-btn__icon" aria-hidden="true">📍</span>
                <span class="cta-cta-branch-btn__content">
                  <span class="cta-cta-branch-btn__name">{branch.name}</span>
                  <span class="cta-cta-branch-btn__address">{branch.address}, {branch.city}</span>
                </span>
                <svg class="cta-cta-branch-btn__arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M7 17L17 7M17 7H7M17 7v10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            );
          })}
        </div>
      </div>

      <div class="cta-final__divider">
        <span>o</span>
      </div>

      <Button href={`tel:${SITE.phone}`} variant="outline" size="lg">
        Llamar ahora — {SITE.phone}
      </Button>

      <div class="cta-final__trust">
        <span>2 sucursales en La Serena</span>
        <span class="cta-final__sep" aria-hidden="true">·</span>
        <span>Lun–Vie 09:30–18:00</span>
        <span class="cta-final__sep" aria-hidden="true">·</span>
        <span>⭐ 5.0 en Google</span>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-final {
    position: relative;
    text-align: center;
    overflow: hidden;
  }

  .cta-final__glow--1 {
    width: 500px;
    height: 500px;
    top: -100px;
    left: 50%;
    transform: translateX(-50%);
    opacity: 0.12;
  }

  .cta-final__glow--2 {
    width: 400px;
    height: 400px;
    bottom: -80px;
    right: 10%;
    opacity: 0.08;
    animation-delay: -5s;
  }

  .cta-final__inner {
    position: relative;
    z-index: var(--z-above);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-6);
  }

  .cta-final__label {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-wide);
    color: var(--color-text-muted);
  }

  .cta-final__dot {
    width: 8px;
    height: 8px;
    background: #2ECC71;
    border-radius: 50%;
    flex-shrink: 0;
    animation: pulse-gold 2s ease-in-out infinite;
  }

  .cta-final__title {
    font-size: clamp(var(--text-4xl), 6vw, var(--text-6xl));
    line-height: var(--leading-tight);
  }

  .cta-final__sub {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    max-width: 420px;
    line-height: var(--leading-relaxed);
  }

  /* Branch selector */
  .cta-final__branches {
    width: 100%;
    max-width: 480px;
  }

  .cta-final__branches-label {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: var(--space-4);
  }

  .cta-final__cta-branch-btns {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .cta-branch-btn {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-4) var(--space-5);
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    text-decoration: none;
    transition: border-color var(--transition-fast), background var(--transition-fast), transform var(--transition-fast);
    text-align: left;
  }

  .cta-branch-btn:hover {
    border-color: var(--color-gold);
    background: color-mix(in srgb, var(--color-gold) 6%, var(--color-bg-surface));
    transform: translateY(-1px);
  }

  .cta-branch-btn__icon {
    font-size: 1.5rem;
    flex-shrink: 0;
  }

  .cta-branch-btn__content {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .cta-branch-btn__name {
    font-size: var(--text-base);
    font-weight: var(--weight-semibold);
    color: var(--color-text-primary);
  }

  .cta-branch-btn__address {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .cta-branch-btn__arrow {
    flex-shrink: 0;
    color: var(--color-gold);
    opacity: 0;
    transition: opacity var(--transition-fast), transform var(--transition-fast);
  }

  .cta-branch-btn:hover .cta-branch-btn__arrow {
    opacity: 1;
    transform: translateX(2px) translateY(-2px);
  }

  /* Divider */
  .cta-final__divider {
    display: flex;
    align-items: center;
    width: 100%;
    max-width: 480px;
    gap: var(--space-4);
    color: var(--color-text-muted);
    font-size: var(--text-sm);
  }

  .cta-final__divider::before,
  .cta-final__divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--color-border);
  }

  .cta-final__trust {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    justify-content: center;
    align-items: center;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border);
    width: 100%;
  }

  .cta-final__sep { color: var(--color-border-hover); }

  .cta-final__logo {
    height: 110px;
    width: auto;
    object-fit: contain;
    filter: drop-shadow(0 4px 16px rgba(0,0,0,0.4));
    margin-bottom: var(--space-2);
  }

  @media (max-width: 640px) {
    .cta-final__branches { max-width: 100%; }
  }
</style>
