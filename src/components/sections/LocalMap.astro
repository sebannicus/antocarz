---
/**
 * LocalMap.astro — Antocarz
 * Dirección, horario y contacto. Dos sucursales. SEO local La Serena.
 */

import SectionLabel from '../ui/SectionLabel.astro';
import Button from '../ui/Button.astro';
import { SITE } from '../../content/site';

const branches = SITE.branches;
---

<section class="localmap section section--surface" id="sucursales" aria-labelledby="map-heading">
  <div class="container">
    <div class="localmap__inner">
      <div class="localmap__info gs-slide-left">
        <SectionLabel text="DÓNDE ENCONTRARNOS" />
        <h2 class="localmap__title" id="map-heading">
          2 sucursales en<br />
          <span class="text-gradient-gold">La Serena.</span>
        </h2>

        <!-- Branch tabs -->
        <div class="localmap__tabs" role="tablist" aria-label="Seleccionar sucursal">
          {branches.map((branch, i) => (
            <button
              class={`localmap__tab ${i === 0 ? 'localmap__tab--active' : ''}`}
              role="tab"
              aria-selected={i === 0 ? 'true' : 'false'}
              aria-controls={`panel-${branch.id}`}
              id={`tab-${branch.id}`}
              data-branch={branch.id}
            >
              {branch.name}
            </button>
          ))}
        </div>

        {branches.map((branch, i) => (
          <div
            class={`localmap__panel ${i === 0 ? 'localmap__panel--active' : ''}`}
            role="tabpanel"
            id={`panel-${branch.id}`}
            aria-labelledby={`tab-${branch.id}`}
          >
            <div class="localmap__data">
              <div class="localmap__row">
                <span class="localmap__icon" aria-hidden="true">📍</span>
                <div>
                  <p class="localmap__label">Dirección</p>
                  <a href={branch.mapsUrl} target="_blank" rel="noopener noreferrer" class="localmap__value link-gold">
                    {branch.address}, {branch.city}
                  </a>
                </div>
              </div>

              <div class="localmap__row">
                <span class="localmap__icon" aria-hidden="true">🕐</span>
                <div>
                  <p class="localmap__label">Horario</p>
                  <p class="localmap__value">{SITE.hours.weekdays}</p>
                  <p class="localmap__value">{SITE.hours.saturday}</p>
                  <p class="localmap__value localmap__value--muted">{SITE.hours.sunday}</p>
                </div>
              </div>

              <div class="localmap__row">
                <span class="localmap__icon" aria-hidden="true">📞</span>
                <div>
                  <p class="localmap__label">Teléfono</p>
                  <a href={`tel:${SITE.phone}`} class="localmap__value link-gold">{SITE.phone}</a>
                </div>
              </div>
            </div>

            <Button
              href={`https://wa.me/${SITE.whatsapp}?text=${encodeURIComponent(branch.whatsappMsg)}`}
              variant="primary"
              size="lg"
              external={true}
            >
              Agendar en {branch.name}
            </Button>
          </div>
        ))}
      </div>

      <!-- Map -->
      <div class="localmap__map-wrap gs-slide-right">
        {branches.map((branch, i) => (
          <iframe
            class={`localmap__map ${i === 0 ? 'localmap__map--active' : ''}`}
            id={`map-${branch.id}`}
            src={branch.mapsEmbed}
            width="100%"
            height="400"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title={`Ubicación Antocarz — ${branch.address}, ${branch.city}`}
          ></iframe>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('.localmap__tab');
  const panels = document.querySelectorAll<HTMLDivElement>('.localmap__panel');
  const maps = document.querySelectorAll<HTMLIFrameElement>('.localmap__map');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const branchId = tab.dataset.branch;

      tabs.forEach((t) => {
        t.classList.remove('localmap__tab--active');
        t.setAttribute('aria-selected', 'false');
      });
      panels.forEach((p) => p.classList.remove('localmap__panel--active'));
      maps.forEach((m) => m.classList.remove('localmap__map--active'));

      tab.classList.add('localmap__tab--active');
      tab.setAttribute('aria-selected', 'true');
      document.getElementById(`panel-${branchId}`)?.classList.add('localmap__panel--active');
      document.getElementById(`map-${branchId}`)?.classList.add('localmap__map--active');
    });
  });
</script>

<style>
  .localmap__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-16);
    align-items: start;
  }

  @media (min-width: 1024px) {
    .localmap__inner { grid-template-columns: 1fr 1fr; align-items: start; }
  }

  .localmap__info {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .localmap__title {
    font-size: clamp(var(--text-3xl), 4vw, var(--text-5xl));
  }

  /* Tabs */
  .localmap__tabs {
    display: flex;
    gap: var(--space-2);
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--space-1);
  }

  .localmap__tab {
    flex: 1;
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-lg);
    border: none;
    background: transparent;
    cursor: pointer;
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-text-muted);
    transition: background var(--transition-fast), color var(--transition-fast);
    white-space: nowrap;
  }

  .localmap__tab--active {
    background: var(--color-gold);
    color: #000;
    font-weight: var(--weight-semibold);
  }

  /* Panels */
  .localmap__panel {
    display: none;
    flex-direction: column;
    gap: var(--space-6);
  }

  .localmap__panel--active {
    display: flex;
  }

  .localmap__data {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .localmap__row {
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
  }

  .localmap__icon {
    font-size: var(--text-xl);
    flex-shrink: 0;
    margin-top: 2px;
  }

  .localmap__label {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: var(--space-1);
  }

  .localmap__value {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
  }

  .localmap__value--muted { color: var(--color-text-muted); }

  /* Map */
  .localmap__map-wrap {
    border-radius: var(--radius-xl);
    overflow: hidden;
    border: 1px solid var(--color-border);
    position: relative;
  }

  .localmap__map {
    display: none;
    width: 100%;
  }

  .localmap__map--active {
    display: block;
  }
</style>
