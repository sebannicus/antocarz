---
/**
 * LocalMap.astro — Antocarz
 * Dirección, horario y contacto. Refuerza SEO local para La Serena.
 */

import SectionLabel from '../ui/SectionLabel.astro';
import Button from '../ui/Button.astro';
import { SITE } from '../../content/site';

const whatsappMsg = encodeURIComponent('Hola, quiero cotizar un servicio para mi vehículo.');
const whatsappUrl = `https://wa.me/${SITE.whatsapp}?text=${whatsappMsg}`;
---

<section class="localmap section section--surface" aria-labelledby="map-heading">
  <div class="container">
    <div class="localmap__inner">
      <div class="localmap__info gs-slide-left">
        <SectionLabel text="DÓNDE ENCONTRARNOS" />
        <h2 class="localmap__title" id="map-heading">
          Estamos en<br />
          <span class="text-gradient-gold">La Serena.</span>
        </h2>

        <div class="localmap__data">
          <div class="localmap__row">
            <span class="localmap__icon" aria-hidden="true">📍</span>
            <div>
              <p class="localmap__label">Dirección</p>
              <a href={SITE.location.mapsUrl} target="_blank" rel="noopener noreferrer" class="localmap__value link-gold">
                {SITE.location.address}, {SITE.location.city}
              </a>
            </div>
          </div>

          <div class="localmap__row">
            <span class="localmap__icon" aria-hidden="true">🕐</span>
            <div>
              <p class="localmap__label">Horario</p>
              <p class="localmap__value">{SITE.hours.weekdays}</p>
              <p class="localmap__value">{SITE.hours.saturday}</p>
              <p class="localmap__value localmap__value--muted">{SITE.hours.sunday}</p>
            </div>
          </div>

          <div class="localmap__row">
            <span class="localmap__icon" aria-hidden="true">📞</span>
            <div>
              <p class="localmap__label">Teléfono</p>
              <a href={`tel:${SITE.phone}`} class="localmap__value link-gold">{SITE.phone}</a>
            </div>
          </div>

          <div class="localmap__row">
            <span class="localmap__icon" aria-hidden="true">✉️</span>
            <div>
              <p class="localmap__label">Email</p>
              <a href={`mailto:${SITE.email}`} class="localmap__value link-gold">{SITE.email}</a>
            </div>
          </div>
        </div>

        <Button href={whatsappUrl} variant="primary" size="lg" external={true}>
          Agendar por WhatsApp
        </Button>
      </div>

      <div class="localmap__map-wrap gs-slide-right">
        <iframe
          class="localmap__map"
          src="https://maps.google.com/maps?q=Antocarz+Lautaro+812+La+Serena+Chile&output=embed&hl=es"
          width="100%"
          height="400"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Ubicación Antocarz — Lautaro 812, La Serena"
        ></iframe>
      </div>
    </div>
  </div>
</section>

<style>
  .localmap__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-16);
    align-items: start;
  }

  @media (min-width: 1024px) {
    .localmap__inner { grid-template-columns: 1fr 1fr; align-items: center; }
  }

  .localmap__info {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .localmap__title {
    font-size: clamp(var(--text-3xl), 4vw, var(--text-5xl));
  }

  .localmap__data {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .localmap__row {
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
  }

  .localmap__icon {
    font-size: var(--text-xl);
    flex-shrink: 0;
    margin-top: 2px;
  }

  .localmap__label {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: var(--space-1);
  }

  .localmap__value {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
  }

  .localmap__value--muted { color: var(--color-text-muted); }

  /* Map */
  .localmap__map-wrap {
    border-radius: var(--radius-xl);
    overflow: hidden;
    border: 1px solid var(--color-border);
  }

  .localmap__map { display: block; width: 100%; }
</style>
