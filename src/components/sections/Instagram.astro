---
/**
 * Instagram.astro — Antocarz
 * Feed automático de Instagram via Behold.so
 *
 * SETUP (5 minutos):
 * 1. Ir a https://behold.so → Sign Up gratis
 * 2. Conectar la cuenta @antocarzlaserena
 * 3. Crear un feed → copiar el FEED ID (ej: "AbCd1234")
 * 4. Reemplazar BEHOLD_FEED_ID abajo con tu ID real
 */

const BEHOLD_FEED_ID = 'Nv26d89sn1o6MdGZ2U5Q'; // ← ID del cliente en Behold.so
const IG_HANDLE     = 'antocarzlaserena';
const IG_URL        = 'https://www.instagram.com/antocarzlaserena/';
---

<section class="ig section section--surface" id="instagram" aria-labelledby="ig-heading">
  <div class="container">

    <!-- Header -->
    <div class="ig__header" data-scroll-children>
      <div class="ig__brand">
        <svg class="ig__icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" width="28" height="28">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
        </svg>
        <div>
          <h2 class="ig__title" id="ig-heading">
            <a href={IG_URL} target="_blank" rel="noopener noreferrer" class="ig__handle">
              @{IG_HANDLE}
            </a>
          </h2>
          <p class="ig__sub">Instalaciones, novedades y más desde La Serena</p>
        </div>
      </div>

      <a href={IG_URL} target="_blank" rel="noopener noreferrer" class="ig__follow-btn">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
        </svg>
        Seguir en Instagram
      </a>
    </div>

    <!-- Feed: Behold.so widget (activo cuando hay FEED ID) -->
    {BEHOLD_FEED_ID ? (
      <div class="ig__feed-live" id="ig-feed-live">
        <behold-widget feed-id={BEHOLD_FEED_ID}></behold-widget>
      </div>
    ) : (
      <!-- Placeholder visual hasta configurar Behold.so -->
      <a href={IG_URL} target="_blank" rel="noopener noreferrer" class="ig__placeholder">
        <div class="ig__placeholder-grid">
          {Array.from({ length: 6 }).map(() => (
            <div class="ig__placeholder-cell" aria-hidden="true">
              <div class="ig__placeholder-inner">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                </svg>
              </div>
            </div>
          ))}
        </div>
        <p class="ig__placeholder-note">Ver nuestro Instagram →</p>
      </a>
    )}

  </div>
</section>

<!-- Script de Behold.so (solo se carga si hay feed ID) -->
{BEHOLD_FEED_ID && (
  <script src="https://w.behold.so/widget.js" type="module" is:inline></script>
)}

<style>
  /* ── Fondo Difuminado Rojo ── */
  .ig {
    background: radial-gradient(circle at center, rgba(227, 6, 19, 0.05) 0%, var(--color-bg-surface) 65%);
    border-top: 1px solid rgba(227, 6, 19, 0.1);
    border-bottom: 1px solid rgba(227, 6, 19, 0.1);
  }

  /* ── Header ── */
  .ig__header {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
    margin-bottom: var(--space-10);
  }

  .ig__brand {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .ig__icon {
    color: var(--color-gold);
    flex-shrink: 0;
  }

  .ig__title {
    font-size: var(--text-xl);
    font-weight: var(--weight-extrabold);
    color: var(--color-text-primary);
    line-height: 1.2;
  }

  .ig__handle {
    color: var(--color-gold);
    text-decoration: none;
    transition: opacity var(--transition-fast);
  }
  .ig__handle:hover { opacity: 0.8; }

  .ig__sub {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-top: 2px;
  }

  .ig__follow-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-6);
    background: linear-gradient(135deg, #E1306C, #F77737, #FCAF45);
    color: #fff;
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    font-weight: var(--weight-bold);
    text-decoration: none;
    transition: opacity var(--transition-base), transform var(--transition-spring);
    box-shadow: 0 4px 20px rgba(225, 48, 108, 0.30);
    white-space: nowrap;
  }

  .ig__follow-btn:hover {
    opacity: 0.92;
    transform: translateY(-2px);
  }

  /* ── Live feed ── */
  .ig__feed-live {
    width: 100%;
  }

  /* ── Placeholder grid ── */
  .ig__placeholder {
    display: block;
    text-decoration: none;
  }

  .ig__placeholder-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 4px;
    border-radius: var(--radius-xl);
    overflow: hidden;
  }

  @media (min-width: 640px) {
    .ig__placeholder-grid { grid-template-columns: repeat(6, 1fr); gap: 6px; }
  }

  .ig__placeholder-cell {
    aspect-ratio: 1 / 1;
    background: var(--color-bg-overlay);
    border: 1px solid var(--color-border);
  }

  .ig__placeholder-inner {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-border-hover);
    transition: color var(--transition-base);
  }

  .ig__placeholder:hover .ig__placeholder-inner {
    color: var(--color-gold);
  }

  .ig__placeholder-note {
    text-align: center;
    font-size: var(--text-sm);
    color: var(--color-gold);
    margin-top: var(--space-4);
    font-weight: var(--weight-medium);
    transition: opacity var(--transition-fast);
  }

  .ig__placeholder:hover .ig__placeholder-note {
    opacity: 0.8;
  }
</style>
