---
/**
 * Authority.astro — Antocarz
 * Métricas de confianza: Google rating, instalaciones, marcas, horario.
 */
---

<section class="authority section" aria-label="Por qué elegirnos">
  <!-- Marca de agua logo centrada -->
  <img
    src="/logos/PNG PEQUE LOGO.png"
    alt=""
    class="authority__watermark"
    aria-hidden="true"
    loading="lazy"
  />
  <div class="container">
    <div class="authority__grid" data-scroll-children>
      <div class="authority__item">
        <span class="authority__value">⭐ 5.0</span>
        <span class="authority__label">Calificación Google</span>
      </div>
      <div class="authority__divider" aria-hidden="true"></div>
      <div class="authority__item">
        <span class="authority__value">+1.000</span>
        <span class="authority__label">Trabajos garantizados</span>
      </div>
      <div class="authority__divider" aria-hidden="true"></div>
      <div class="authority__item">
        <span class="authority__value">+643</span>
        <span class="authority__label">Certificados de polarizado emitidos</span>
      </div>
      <div class="authority__divider" aria-hidden="true"></div>
      <div class="authority__item">
        <span class="authority__value">JBL · Pioneer</span>
        <span class="authority__label">Marcas que instalamos</span>
      </div>
    </div>
  </div>
</section>

<style>
  .authority {
    position: relative;
    padding-block: var(--space-12);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    overflow: hidden;
  }

  .authority__watermark {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    height: 220px;
    width: auto;
    object-fit: contain;
    opacity: 0.04;
    pointer-events: none;
    user-select: none;
    filter: grayscale(1);
  }

  .authority__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    align-items: center;
    text-align: center;
  }

  .authority__divider {
    display: none;
    width: 1px;
    height: 40px;
    background: var(--color-border);
    margin-inline: auto;
  }

  @media (min-width: 640px) {
    .authority__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .authority__grid {
      grid-template-columns: 1fr auto 1fr auto 1fr auto 1fr;
      text-align: left;
    }
    .authority__divider { display: block; }
  }

  .authority__item {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    justify-content: center;
    align-items: center;
  }

  @media (min-width: 1024px) {
    .authority__item { align-items: flex-start; }
  }

  .authority__value {
    font-family: var(--font-headline);
    font-size: var(--text-2xl);
    font-weight: var(--weight-extrabold);
    background: linear-gradient(135deg, var(--color-gold), var(--color-gold-light));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1;
  }

  .authority__label {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    font-weight: var(--weight-medium);
  }
</style>
