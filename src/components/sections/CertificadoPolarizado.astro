---
/**
 * CertificadoPolarizado.astro — Antocarz
 * Sección SEO + descarga del modelo de certificado legal de polarizado.
 * Objetivo: capturar tráfico de "certificado de polarizado", "cómo sacar certificado polarizado".
 */

import SectionLabel from '../ui/SectionLabel.astro';
import { SITE } from '../../content/site';

const whatsappMsg = encodeURIComponent('Hola Antocarz 👋 Quiero instalar polarizado nanocarbón y obtener mi certificado legal. ¿Me pueden cotizar?');
const whatsappUrl = `https://wa.me/${SITE.whatsapp}?text=${whatsappMsg}`;
---

<section class="cert section section--surface" id="polarizado" aria-labelledby="cert-heading">
  <div class="container">

    <div class="cert__layout">

      <!-- Columna izquierda: información -->
      <div class="cert__info gs-fade-up">
        <SectionLabel text="CERTIFICADO LEGAL" />
        <h2 class="cert__title" id="cert-heading">
          Polarizado legal con<br />
          <span class="text-gradient-gold">certificado incluido.</span>
        </h2>
        <p class="cert__desc">
          En Antocarz emitimos el certificado de instalación exigido por la Ley de Polarizados vigente en Chile, con más de <strong>+10.000 certificados</strong> entregados en La Serena y la Región de Coquimbo.
        </p>

        <ul class="cert__checks" role="list">
          <li class="cert__check">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true"><circle cx="9" cy="9" r="9" fill="#C9A227" opacity="0.15"/><path d="M5 9l3 3 5-5" stroke="#C9A227" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Sello en relieve por vidrio (exigencia legal)
          </li>
          <li class="cert__check">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true"><circle cx="9" cy="9" r="9" fill="#C9A227" opacity="0.15"/><path d="M5 9l3 3 5-5" stroke="#C9A227" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Porcentajes legales: 5%, 20% y 35%
          </li>
          <li class="cert__check">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true"><circle cx="9" cy="9" r="9" fill="#C9A227" opacity="0.15"/><path d="M5 9l3 3 5-5" stroke="#C9A227" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Láminas nanocarbón certificadas con RUT instalador
          </li>
          <li class="cert__check">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true"><circle cx="9" cy="9" r="9" fill="#C9A227" opacity="0.15"/><path d="M5 9l3 3 5-5" stroke="#C9A227" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Válido para revisión técnica (CITV) y Carabineros
          </li>
          <li class="cert__check">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true"><circle cx="9" cy="9" r="9" fill="#C9A227" opacity="0.15"/><path d="M5 9l3 3 5-5" stroke="#C9A227" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Transferible al próximo dueño del vehículo
          </li>
        </ul>

        <div class="cert__actions">
          <a
            href={whatsappUrl}
            class="btn btn--primary btn--lg"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Cotizar polarizado con certificado por WhatsApp"
          >
            Cotizar con certificado →
          </a>
        </div>

        <p class="cert__note">
          * Los certificados se emiten únicamente con instalación en tienda. No se venden por separado.
        </p>
      </div>

      <!-- Columna derecha: tarjeta visual del certificado -->
      <div class="cert__card-wrap gs-slide-up">
        <div class="cert__card">
          <div class="cert__card-header">
            <span class="cert__card-badge">Certificado Legal</span>
            <span class="cert__card-logo">ANTOCARZ</span>
          </div>

          <h3 class="cert__card-title">Certificado de Instalación<br />de Lámina Polarizada</h3>

          <div class="cert__card-fields">
            <div class="cert__field">
              <span class="cert__field-label">Instalador</span>
              <span class="cert__field-value">Antocarz · RUT registrado</span>
            </div>
            <div class="cert__field">
              <span class="cert__field-label">Lámina</span>
              <span class="cert__field-value">Nanocarbón certificada</span>
            </div>
            <div class="cert__field">
              <span class="cert__field-label">Transmisión de luz</span>
              <span class="cert__field-value">5% / 20% / 35% según vidrio</span>
            </div>
            <div class="cert__field">
              <span class="cert__field-label">Sello en relieve</span>
              <span class="cert__field-value">Por cada vidrio instalado</span>
            </div>
            <div class="cert__field">
              <span class="cert__field-label">Vigencia</span>
              <span class="cert__field-value">Permanente · Transferible</span>
            </div>
          </div>

          <div class="cert__card-footer">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" stroke="#C9A227" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Cumple Ley de Polarizados · Vigente desde Marzo 2020
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .cert__layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-16);
    align-items: center;
  }

  @media (min-width: 1024px) {
    .cert__layout { grid-template-columns: 1fr 1fr; }
  }

  /* ── Info ── */
  .cert__title {
    font-size: clamp(var(--text-3xl), 4vw, var(--text-5xl));
    margin-block: var(--space-4);
    line-height: var(--leading-tight);
  }

  .cert__desc {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-6);
  }

  .cert__desc strong { color: var(--color-text-primary); }

  .cert__checks {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-bottom: var(--space-8);
  }

  .cert__check {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
  }

  .cert__check svg { flex-shrink: 0; }

  .cert__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    margin-bottom: var(--space-4);
  }

  .cert__note {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  /* ── Tarjeta ── */
  .cert__card-wrap {
    perspective: 1000px;
  }

  .cert__card {
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-2xl);
    padding: var(--space-8);
    position: relative;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0,0,0,0.4);
  }

  .cert__card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 4px;
    background: linear-gradient(90deg, var(--color-gold), var(--color-gold-light), var(--color-gold));
  }

  .cert__card::after {
    content: 'CERTIFICADO';
    position: absolute;
    bottom: 20px;
    right: -30px;
    font-size: 80px;
    font-weight: 900;
    color: rgba(201,162,39,0.04);
    transform: rotate(-20deg);
    pointer-events: none;
    letter-spacing: 4px;
    white-space: nowrap;
  }

  .cert__card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-6);
  }

  .cert__card-badge {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-gold);
    background: rgba(201,162,39,0.1);
    border: 1px solid rgba(201,162,39,0.25);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
  }

  .cert__card-logo {
    font-family: var(--font-headline);
    font-size: var(--text-lg);
    font-weight: var(--weight-extrabold);
    color: var(--color-text-primary);
    letter-spacing: var(--tracking-wide);
  }

  .cert__card-title {
    font-family: var(--font-headline);
    font-size: var(--text-xl);
    font-weight: var(--weight-bold);
    color: var(--color-text-primary);
    margin-bottom: var(--space-6);
    line-height: var(--leading-tight);
  }

  .cert__card-fields {
    display: flex;
    flex-direction: column;
    gap: 0;
    border-top: 1px solid var(--color-border);
  }

  .cert__field {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-4);
    padding-block: var(--space-3);
    border-bottom: 1px solid var(--color-border);
  }

  .cert__field-label {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    flex-shrink: 0;
  }

  .cert__field-value {
    font-size: var(--text-sm);
    color: var(--color-text-primary);
    font-weight: var(--weight-medium);
    text-align: right;
  }

  .cert__card-footer {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-top: var(--space-5);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }
</style>
