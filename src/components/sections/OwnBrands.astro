---
/**
 * OwnBrands.astro — Antocarz
 * Sección de marcas propias: ZTAudio y rastreadores.cl
 */

import SectionLabel from '../ui/SectionLabel.astro';
import { SITE } from '../../content/site';

const brands = SITE.partnerBrands;
---

<section class="own-brands section" id="marcas-propias" aria-labelledby="own-brands-heading">
  <div class="bg-glow bg-glow--gold own-brands__glow" aria-hidden="true"></div>

  <div class="container">
    <div class="own-brands__header gs-fade-up">
      <SectionLabel text="MARCAS EXCLUSIVAS" />
      <h2 class="own-brands__title" id="own-brands-heading">
        Tecnología propia,<br />
        <span class="text-gradient-gold">calidad garantizada.</span>
      </h2>
      <p class="own-brands__subtitle">
        Distribuimos y trabajamos con marcas propias que nos permiten ofrecerte
        los mejores precios sin sacrificar calidad. Todos nuestros productos cuentan con garantía.
      </p>
    </div>  

    <div class="own-brands__grid">
      {brands.map((brand) => (
        <article class="own-brand-card gs-slide-up" data-brand={brand.id}>
          <div class="own-brand-card__header">
            <img
              src={brand.logo}
              alt={brand.name}
              class="own-brand-card__logo"
              width="160"
              height="48"
              loading="lazy"
            />
            <span class="own-brand-card__badge" style={`--brand-color: ${brand.color}`}>
              {brand.badge}
            </span>
          </div>

          <p class="own-brand-card__tagline" style={`color: ${brand.color}`}>
            {brand.tagline}
          </p>

          <p class="own-brand-card__desc">{brand.description}</p>
          
          <div class="own-brand-card__product-image">
            {brand.images && brand.images.length > 1 ? (
              <div class="ob-carousel">
                {brand.images.map((src: string, i: number) => (
                  <div class="ob-carousel__slide">
                    <img src={src} alt={i === 0 ? brand.name : `${brand.name} ${i + 1}`} loading={i === 0 ? 'eager' : 'lazy'} />
                  </div>
                ))}
              </div>
            ) : (
              <img src={brand.image} alt={brand.name} loading="lazy" />
            )}
          </div>

          <ul class="own-brand-card__features" role="list">
            {brand.features.map((feat) => (
              <li class="own-brand-card__feat" style={`--brand-color: ${brand.color}`}>
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                  <circle cx="7" cy="7" r="7" fill="currentColor" opacity="0.15"/>
                  <path d="M4 7l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                {feat}
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .own-brands {
    position: relative;
    overflow: hidden;
  }

  .own-brands__glow {
    width: 600px;
    height: 600px;
    top: -100px;
    left: -200px;
    opacity: 0.06;
  }

  .own-brands__header {
    text-align: center;
    max-width: 600px;
    margin: 0 auto var(--space-16);
  }

  .own-brands__title {
    font-size: clamp(var(--text-3xl), 4vw, var(--text-5xl));
    margin-block: var(--space-4);
  }

  .own-brands__subtitle {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
  }

  .own-brands__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
  }

  @media (min-width: 768px) {
    .own-brands__grid { grid-template-columns: 1fr 1fr; }
  }

  /* Card */
  .own-brand-card {
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-2xl);
    padding: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    transition: border-color var(--transition-base), transform var(--transition-base);
  }

  .own-brand-card:hover {
    border-color: var(--color-border-hover);
    transform: translateY(-2px);
  }

  .own-brand-card__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
  }

  .own-brand-card__logo {
    height: 44px;
    width: auto;
    object-fit: contain;
    filter: drop-shadow(0 2px 8px rgba(0,0,0,0.3));
  }

  .own-brand-card__badge {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--brand-color, var(--color-gold));
    background: color-mix(in srgb, var(--brand-color, var(--color-gold)) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--brand-color, var(--color-gold)) 30%, transparent);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
    white-space: nowrap;
  }

  .own-brand-card__tagline {
    font-size: var(--text-lg);
    font-weight: var(--weight-semibold);
    line-height: var(--leading-tight);
  }

  .own-brand-card__desc {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
  }

  .own-brand-card__product-image {
    width: 100%;
    aspect-ratio: 16/9;
    border-radius: var(--radius-xl);
    overflow: hidden;
    margin-top: var(--space-4);
    background: #111;
  }

  .own-brand-card__product-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow);
  }

  .own-brand-card:hover > .own-brand-card__product-image > img {
    transform: scale(1.05);
  }

  /* Carrusel táctil */
  .ob-carousel {
    display: flex;
    width: 100%;
    height: 100%;
    overflow-x: scroll;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .ob-carousel::-webkit-scrollbar { display: none; }

  .ob-carousel__slide {
    flex: 0 0 100%;
    width: 100%;
    height: 100%;
    scroll-snap-align: start;
  }

  .ob-carousel__slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .own-brand-card__features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-top: var(--space-2);
    padding-top: var(--space-5);
    border-top: 1px solid var(--color-border);
  }

  .own-brand-card__feat {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
  }

  .own-brand-card__feat svg {
    flex-shrink: 0;
    color: var(--brand-color, var(--color-gold));
  }
</style>
