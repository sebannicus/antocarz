---
/**
 * Brands.astro — Antocarz
 * Logos de marcas que instalan en marquee infinito.
 */

const brands = [
  { name: 'JBL',     src: '/logos/jbl.svg',     w: 80  },
  { name: 'Pioneer', src: '/logos/pioneer.svg',  w: 120 },
  { name: 'Hawk',    src: '/logos/hawk.svg',     w: 95  },
  { name: 'BRM',     src: '/logos/brm.svg',      w: 80  },
];

// Triplicar para que el loop sea fluido en pantallas anchas
const items = [...brands, ...brands, ...brands];
---

<section class="brands" aria-label="Marcas que instalamos">
  <div class="container">
    <p class="brands__label">Marcas que instalamos</p>
  </div>

  <div class="brands__marquee marquee">
    <div class="marquee__track">
      {items.map((b) => (
        <img
          src={b.src}
          alt={b.name}
          width={b.w}
          height={50}
          class="brands__logo"
          loading="lazy"
          draggable="false"
        />
      ))}
    </div>
  </div>
</section>

<style>
  .brands {
    padding-block: var(--space-8);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    background: var(--color-bg-surface);
    overflow: hidden;
  }

  .brands__label {
    text-align: center;
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: var(--space-6);
  }

  .brands__marquee {
    animation: marquee 18s linear infinite;
  }

  .brands__logo {
    height: 40px;
    width: auto;
    object-fit: contain;
    opacity: 0.85;
    flex-shrink: 0;
    transition: opacity var(--transition-fast);
    border-radius: 4px;
  }

  .brands__logo:hover {
    opacity: 1;
  }

  .marquee__track {
    display: flex;
    align-items: center;
    gap: var(--space-12);
  }
</style>
